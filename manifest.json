{
  "manifest_version": 3,
  "name": "Phish Catcher",
  "version": "1.0",
  "description": "Helps detect and flag potential phishing pages as you browse.",
  "permissions": ["activeTab", "scripting", "storage"],
  "action": {
    "default_icon": "icon.png",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
